{
  "extends": "../../packages/config/typescript/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "target": "es2020",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true

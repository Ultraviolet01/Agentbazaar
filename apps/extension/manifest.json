{
  "manifest_version": 3,
  "name": "ScamSniff",
  "version": "1.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://api.elevenlabs.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("AGENTBAZAAR_DB_URL")
  directUrl = env("AGENTBAZAAR_DIRECT_URL")
}

model User {
  id                  String        @id @default(cuid())
  email               String        @unique
  username            String        @unique
  passwordHash        String
  credits             Float         @default(20)
  emailVerified       Boolean       @default(false)
  verificationToken   String?
  refreshToken        String?
  resetToken          String?
  resetTokenExpires   DateTime?
  onboardingCompleted Boolean       @default(false)
  walletAddress       String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  agentRuns           AgentRun[]
  projects            Project[]
  transactions        Transaction[]
  monitoringJobs      MonitoringJob[]
  launchWatchAlerts   LaunchWatchAlert[]
}

model MonitoringJob {
  id               String   @id @default(cuid())
  userId           String
  type             String   // 'project', 'token_milestone', 'crypto_news'
  email            String
  status           String   @default("active") // 'active', 'paused', 'completed'
  setupCost        Float
  
  // Project monitoring data
  projectUrl       String?
  monitorSocial    Boolean  @default(false)
  monitorWebsite   Boolean  @default(false)
  monitorSentiment Boolean  @default(false)
  checkFrequency   String?  // 'hourly', 'daily', 'weekly'
  
  // Token milestone data
  contractAddress  String?
  tokenSymbol      String?
  currentFDV       Float?
  targetFDV        Float?
  
  // News data
  newsTopics       String   @default("[]") // JSON array as string (SQLite compatibility)
  newsFrequency    String?  // 'realtime', 'daily', 'weekly'
  
  // Tracking
  nextCheck        DateTime?
  lastCheck        DateTime?
  totalChecks      Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
}

model Project {
  id                String             @id @default(cuid())
  userId            String
  name              String
  description       String?
  websiteUrl        String?
  twitterHandle     String?
  tokenAddress      String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  agentRuns         AgentRun[]
  memories          ProjectMemory[]
  launchWatchConfig LaunchWatchConfig?
  launchWatchAlerts LaunchWatchAlert[]
  user              User               @relation(fields: [userId], references: [id])
}

model AgentRun {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  agentType   AgentType
  creditsUsed Float
  status      String
  inputData   Json
  outputData  Json?
  artifactCid String?
  createdAt   DateTime @default(now())
  project     Project? @relation(fields: [projectId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String
  status      String
  description String?
  txHash      String?  @unique
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model ProjectMemory {
  id          String   @id @default(cuid())
  projectId   String
  sourceAgent String
  memoryType  String
  content     Json
  storageCid  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])
}

model LaunchWatchConfig {
  id           String    @id @default(cuid())
  projectId    String    @unique
  frequency    String
  active       Boolean   @default(true)
  alertTypes   Json?
  emailEnabled Boolean   @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  project      Project   @relation(fields: [projectId], references: [id])
}

model LaunchWatchAlert {
  id          String        @id @default(cuid())
  projectId   String
  userId      String
  alertType   String
  severity    AlertSeverity
  message     String
  metadata    Json?
  emailSent   Boolean       @default(false)
  emailSentAt DateTime?
  read        Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project       @relation(fields: [projectId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
}

enum AgentType {
  SCAMSNIFF
  THREADSMITH
  LAUNCHWATCH
}

enum AlertSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
